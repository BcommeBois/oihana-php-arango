{
    "name": "oihana/php-arango",
    "type": "library",
    "description": "Composable PHP toolkit for ArangoDB. Bundles a modern HTTP client (collections, documents, edges, AQL, cursors, indexes, transactions, graphs, analyzers, views), a high-level façade, document/edge models with trait-based composition, controllers, helpers and CLI commands.",
    "keywords": [
        "php",
        "arangodb",
        "arango",
        "aql",
        "nosql",
        "graph-database",
        "document-database",
        "transactions",
        "analyzers",
        "arangosearch",
        "casbin",
        "rbac",
        "client",
        "http-client"
    ],
    "homepage": "https://github.com/BcommeBois/oihana-php-arango",
    "license": "MPL-2.0",
    "authors": [
        {
            "name": "Marc Alcaraz",
            "email": "marc@ooop.fr",
            "homepage": "https://www.ooop.fr",
            "role": "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr",
        "issues": "https://github.com/BcommeBois/oihana-php-arango/issues",
        "source": "https://github.com/BcommeBois/oihana-php-arango"
    },
    "scripts": {
        "doc": "rm -rf docs && ./vendor/bin/phpdoc -c phpdoc.xml -v",
        "analyse": "./vendor/bin/phpstan analyse",
        "test": "./vendor/bin/phpunit",
        "test:integration": "./vendor/bin/phpunit -c phpunit-integration.xml",
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html",
        "coverage:md": [
            "@coverage",
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ],
        "test:clients": "php bin/console.php command:arango:test:clients",
        "test:facade": "php bin/console.php command:arango:test:facade",
        "arango": "php bin/console.php command:arangodb",
        "arango:dump": "php bin/console.php command:arangodb dump",
        "arango:restore": "php bin/console.php command:arangodb restore",
        "arango:list": "php bin/console.php command:arangodb dump --list",
        "arango:views": "php bin/console.php command:arangodb views",
        "arango:analyzers": "php bin/console.php command:arangodb analyzers",
        "arango:doctor": "php bin/console.php command:arangodb doctor"
    },
    "scripts-descriptions": {
        "doc": "Generate the phpDocumentor API documentation under docs/.",
        "analyse": "Run the PHPStan static analysis (level 0) over src/.",
        "test": "Run the PHPUnit test suite.",
        "test:integration": "Run the live integration suite (group `integration`) against a real arangod — skips green when no server is reachable (configs/config.toml).",
        "coverage": "Run the suite with code coverage (text + Clover + HTML under build/coverage/). Requires Xdebug or PCOV.",
        "coverage:md": "Regenerate build/coverage/COVERAGE.md, a readable Markdown coverage summary (gitignored, never committed).",
        "test:clients": "Run the live end-to-end smoke test for the clients/ HTTP library against a real arangod.",
        "test:facade": "Run the live end-to-end smoke test for the high-level ArangoDB façade against a real arangod.",
        "arango": "Proxy to bin/console.php command:arangodb (pass action + flags after `--`).",
        "arango:dump": "Dump the ArangoDB database (flags after `--`, e.g. `composer arango:dump -- --encrypt --passphrase X`).",
        "arango:restore": "Restore the ArangoDB database (flags after `--`, e.g. `composer arango:restore -- --last`).",
        "arango:list": "List existing dump archives in the configured dumps directory.",
        "arango:views": "Manage the ArangoSearch Views (list by default; flags after `--`, e.g. `composer arango:views -- --diff`, `-- --sync`, `-- --drop=a,b`).",
        "arango:analyzers": "Manage the custom ArangoSearch analyzers (list by default; flags after `--`, e.g. `composer arango:analyzers -- --diff`, `-- --sync`, `-- --sync --force`, `-- --fix`, `-- --prune`).",
        "arango:doctor": "Diagnose the declared structure against the server (report by default; flags after `--`, e.g. `composer arango:doctor -- --apply`, `-- --apply --force`, `-- --prune`)."
    },
