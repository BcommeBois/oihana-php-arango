<?xml version="1.0" encoding="UTF-8"?>
<!--
    Opt-in live ArangoDB integration suite.

    Runs ONLY the tests tagged `#[Group('integration')]`, which execute real
    AQL against a disposable database built from configs/config.toml. Skipping
    is allowed here (failOnSkipped="false") so the suite stays green on a
    machine without a reachable ArangoDB instance.

    Usage:
        vendor/bin/phpunit -c phpunit-integration.xml
-->
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd"
    backupGlobals="false"
    backupStaticProperties="false"
    beStrictAboutTestsThatDoNotTestAnything="true"
    beStrictAboutOutputDuringTests="true"
    bootstrap="vendor/autoload.php"
    cacheDirectory=".phpunit.cache"
    cacheResult="false"
    colors="true"
    columns="max"
    displayDetailsOnIncompleteTests="true"
    displayDetailsOnSkippedTests="true"
    displayDetailsOnTestsThatTriggerNotices="true"
    displayDetailsOnTestsThatTriggerWarnings="true"
    failOnEmptyTestSuite="false"
    failOnIncomplete="true"
    failOnRisky="true"
    failOnSkipped="false"
    failOnWarning="true"
    processIsolation="false"
    testdox="true"
>
    <testsuites>
        <testsuite name="Integration">
            <directory>./tests</directory>
        </testsuite>
    </testsuites>

    <groups>
        <include>
            <group>integration</group>
        </include>
    </groups>

    <source>
        <include>
            <directory suffix=".php">./src</directory>
        </include>
    </source>

</phpunit>
